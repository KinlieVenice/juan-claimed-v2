model DimBenefitFieldCondition {
  id String @id @default(uuid())

  benefitRuleGroupId String
  benefitRuleGroup   FctBenefitRuleGroup @relation(fields: [benefitRuleGroupId], references: [id])

  benefitFieldConditionId String
  benefitFieldCondition   FctDynamicFieldCondition   @relation("BFC_FDC", fields: [benefitFieldConditionId], references: [id])

  fieldConditionOperatorId String
  fieldConditionOperator   DimFieldConditionOperator @relation(fields: [fieldConditionOperatorId], references: [id])

  conditionFieldValue Json @db.Json

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("BenefitFieldConditionCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("BenefitFieldConditionUpdatedBy", fields: [updatedById], references: [id])

  deletedAt             DateTime?
  fctDynamicRuleGroup   FctDynamicRuleGroup? @relation(fields: [fctDynamicRuleGroupId], references: [id])
  fctDynamicRuleGroupId String?

  @@map("benefit_field_condition")
}

model FctBenefitRuleGroup {
  id String @id @default(uuid())

  benefitId         String
  benefit           FctBenefit?           @relation(fields: [benefitId], references: [id])
  parentRuleGroupId String?
  parentRuleGroup   FctBenefitRuleGroup?  @relation("childFields", fields: [parentRuleGroupId], references: [id])
  childFields       FctBenefitRuleGroup[] @relation("childFields")

  logicalOperator       RuleLogicalOperator        @default(ALL)
  benefitFieldCondition DimBenefitFieldCondition[]

  @@map("fct_benefit_rule_group")
}

enum RuleLogicalOperator {
  ALL
  ANY
}

model FctDynamicRuleGroup {
  id String @id @default(uuid())

  fieldId String
  field   DimField? @relation(fields: [fieldId], references: [id])

  parentRuleGroupId String?
  parentRuleGroup   FctDynamicRuleGroup?  @relation("childFields", fields: [parentRuleGroupId], references: [id])
  childFields       FctDynamicRuleGroup[] @relation("childFields")

  benefitFieldConditions DimBenefitFieldCondition[]
  dynamicFieldConditions FctDynamicFieldCondition[]

  logicalOperator RuleLogicalOperator @default(ALL)

  @@map("fct_dynamic_rule_group")
}

model DimField {
  id String @id @default(uuid())

  // key is the normalized, snake_case form of englishName (lowercased, whitespace/
  // separators collapsed to "_") — e.g. "first_field" == "FirstField" == "FIRST FIELD"
  // == "FIRST   FIELD" == "first-FiEld" all normalize to "first_field". Postgres can't
  // enforce that kind of normalized uniqueness directly on englishName (no case/
  // whitespace-insensitive constraint), so key exists specifically to carry the
  // normalized value and be the actual @unique target — application code computes it
  // at write time.
  key String @unique @db.VarChar(255)

  parentFieldId String?
  parentField   DimField?  @relation("childFields", fields: [parentFieldId], references: [id])
  childFields   DimField[] @relation("childFields")

  // Distinct from parentFieldId (REPEATER_GROUP row-columns, always rendered as part of
  // that table). This field has its own dynamicCondition naming anchorField as one of its
  // "Parent Dependents" (a field it depends on), and wants to render pinned immediately
  // under it instead of at its own flat sortOrder — see field.service.ts's
  // assertAnchorFieldValid (anchorFieldId must be an actual referenced conditionFieldId in
  // this field's own tree) and the auto-detach logic in editField (removing that
  // dependency from the tree resets this back to null).
  anchorFieldId    String?
  anchorField      DimField?  @relation("FieldAnchor", fields: [anchorFieldId], references: [id], onDelete: SetNull)
  anchoredChildren DimField[] @relation("FieldAnchor")

  englishName String @db.VarChar(255)
  tagalogName String @db.VarChar(255)
  englishDescription String
  tagalogDescription String

  fieldInputTypeId String
  fieldInputType   DimFieldInputType @relation(fields: [fieldInputTypeId], references: [id])

  fieldHierarchyId String?
  hierarchy        DimFieldHierarchy? @relation(fields: [fieldHierarchyId], references: [id])

  // Real DB-level link (Prisma implicit many-to-many, not string-matching on englishName)
  // for fields whose options are dynamically sourced from the shared DimCountries reference
  // table instead of real DimFieldOption rows — see fieldOptions.service.ts's
  // fetchFieldOptions. Many-to-many because the same 249 country rows back BOTH the
  // Nationality and Country fields at once; a plain fieldId FK on DimCountries could only
  // ever point at one owner.
  countries DimCountries[]

  required       Boolean             @default(true)
  sortOrder      Int                 @default(0)
  configJson     Json?
  classification FieldClassification @default(FOLLOW_UP)
  // A system-shipped starter field, whether or not it's actually eGovPH-sourced (see
  // eGovField below) — e.g. "Occupation" is `default` but was authored by us, not synced.
  default        Boolean             @default(false)
  // True = this field's VALUE is genuinely sourced from eGovPH (pre-filled on the public
  // form, locked from editing there; name/classification locked in the admin form too).
  // Distinct from `default`: a field can be a system-shipped starter field without being
  // eGov-sourced (see the Occupation example above), so this is the actual signal for
  // "don't let anyone hand-edit this — it either comes from eGovPH or must stay in sync
  // with what eGovPH literally calls it."
  eGovField      Boolean             @default(false)
  // True = this field can still be answered like any other GLOBAL/FOLLOW_UP field, but
  // must not be selectable as a dependency target when an admin builds a benefit's
  // eligibility rule tree (or another field's show/hide condition) — e.g. free-text name/
  // address fields that aren't meaningful eligibility comparators.
  notConditional Boolean             @default(false)

  userFieldAnswers      FctUserFieldAnswer[]
  userFieldAnswerGroups FctUserFieldAnswerGroup[]
  fieldOptions          DimFieldOption[]
  dynamicRuleGroups     FctDynamicRuleGroup[]
  dependentFieldConditions FctDynamicFieldCondition[] @relation("FDC_DF")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("FieldCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("FieldUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("dim_field")
}

enum FieldClassification {
  GLOBAL
  FOLLOW_UP
}

//for context these are some of the types
// 'TEXT',
// 'NUMBER',
// 'DATE',
// 'BOOLEAN',
// 'SINGLE_SELECT',
// 'MULTI_SELECT',
// 'HIERARCHICAL_SELECT'
model DimFieldInputType {
  id          String @id @default(uuid())
  englishName String @db.VarChar(255)
  tagalogName String @db.VarChar(255)
  value       String @unique @db.VarChar(255)

  fields                  DimField[]
  fieldConditionOperators DimFieldConditionOperator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("InputTypeCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("InputTypeUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("dim_field_input_type")
}

model DimFieldOption {
  id String @id @default(uuid())

  fieldId String
  field   DimField @relation(fields: [fieldId], references: [id])

  englishName String @db.VarChar(255)
  tagalogName String @db.VarChar(255)
  value       String @db.VarChar(255)

  englishDescription String
  tagalogDescription String

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("FieldOptionCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("FieldOptionUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@unique([fieldId, value])
  @@map("dim_field_option")
}

model DimFieldHierarchy {
  id          String @id @default(uuid())
  englishName String @db.VarChar(255)
  tagalogName String @db.VarChar(255)

  // Same convention as DimField.key: generated once at creation (generateUniqueCode) and
  // never recomputed on edit — see fieldHierarchy.service.ts's createHierarchyWith. A few
  // well-known SYSTEM hierarchies get a hand-picked key with no hex prefix instead (e.g.
  // "PH_LOCATION", set directly by prisma/seeders/phLocationHierarchySeeder.ts) — the
  // frontend special-cases those exact strings to swap in a purpose-built field component
  // (PsgcPhLocationHierarchyField.tsx) instead of the generic static-node one. Nullable only
  // because rows created before this column existed have none.
  key String? @unique @db.VarChar(255)

  // System-shipped hierarchy (mirrors DimField.default) — reserved for whenever a
  // delete-hierarchy capability gets built, so it can refuse to delete this one. No
  // deletion path exists yet either way; this just marks intent up front.
  default Boolean @default(false)

  englishDescription String
  tagalogDescription String

  fields               DimField[]
  fieldHierarchyLevels DimFieldHierarchyLevel[]
  fieldHierarchyNodes  DimFieldHierarchyNode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("HierarchyCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("HierarchyUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("dim_field_hierarchy")
}

model DimFieldHierarchyLevel {
  id String @id @default(uuid())

  fieldHierarchyId String
  fieldHierarchy   DimFieldHierarchy @relation(fields: [fieldHierarchyId], references: [id])

  level Int @default(1)

  englishName        String @db.VarChar(255)
  tagalogName        String @db.VarChar(255)
  englishDescription String
  tagalogDescription String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("HierarchyLevelCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("HierarchyLevelUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("dim_field_hierarchy_level")
}

model DimFieldHierarchyNode {
  id String @id @default(uuid())

  fieldHierarchyId String
  fieldHierarchy   DimFieldHierarchy @relation(fields: [fieldHierarchyId], references: [id])

  parentNodeId String?
  parentNode   DimFieldHierarchyNode?  @relation("childNodes", fields: [parentNodeId], references: [id])
  childNodes   DimFieldHierarchyNode[] @relation("childNodes")

  englishName        String @db.VarChar(255)
  tagalogName        String @db.VarChar(255)
  value              String @db.VarChar(255)
  englishDescription String
  tagalogDescription String

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("HierarchyNodeCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("HierarchyNodeUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@unique([fieldHierarchyId, value])
  @@map("dim_field_hierarchy_node")
}

model DimFieldConditionOperator {
  id          String @id @default(uuid())
  englishName String @db.VarChar(255)
  tagalogName String @db.VarChar(255)
  // NOT globally unique — the same operator value (e.g. "EQUALS") is legitimately reused
  // across many input types (TEXT, NUMBER, SINGLE_SELECT, ...). Unique per (value,
  // fieldInputTypeId) instead — see fieldConfigSeeder.ts's upsert, keyed on that pair.
  value String @db.VarChar(255)

  fieldInputTypeId String
  fieldInputType   DimFieldInputType @relation(fields: [fieldInputTypeId], references: [id])

  fieldConditions        FctDynamicFieldCondition[]
  benefitFieldConditions DimBenefitFieldCondition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("ConditionOperatorCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("ConditionOperatorUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@unique([value, fieldInputTypeId])
  @@map("dim_field_condition_operator")
}

model FctUserFieldAnswer {
  id String @id @default(uuid())

  userId String
  user   DimUser @relation(fields: [userId], references: [id])

  fieldId String
  field   DimField @relation(fields: [fieldId], references: [id])

  // Set only when answering a REPEATER_GROUP subfield — identifies which row/instance of
  // the repeater this value belongs to. Null for every non-repeater answer. NULL is not
  // unique-constrained by Postgres, so the non-repeater one-answer-per-(user,field)
  // invariant is enforced at the service layer, not by @@unique below.
  repeaterGroupId String?
  repeaterGroup   FctUserFieldAnswerGroup? @relation(fields: [repeaterGroupId], references: [id])

  field_value String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("UserFieldAnswerCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("UserFieldAnswerUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@unique([fieldId, repeaterGroupId])
  @@index([userId, fieldId])
  @@map("fct_user_field_answer")
}

// One row-instance ("row") of a REPEATER_GROUP field for a given user — e.g. one
// dependent, one property owned. FctUserFieldAnswer rows for that repeater's subfields
// reference this via repeaterGroupId to say which row they belong to.
model FctUserFieldAnswerGroup {
  id String @id @default(uuid())

  userId String
  user   DimUser @relation(fields: [userId], references: [id])

  // The REPEATER_GROUP field this row-instance belongs to (the parent field itself,
  // never a subfield).
  fieldId String
  field   DimField @relation(fields: [fieldId], references: [id])

  sortOrder Int @default(0)

  answers FctUserFieldAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("UserFieldAnswerGroupCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("UserFieldAnswerGroupUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("fct_user_field_answer_group")
}

model FctDynamicFieldCondition {
  id String @id @default(uuid())

  dynamicRuleGroupId String
  dynamicRuleGroup   FctDynamicRuleGroup @relation(fields: [dynamicRuleGroupId], references: [id])

  fieldConditionOperatorId String
  fieldConditionOperator   DimFieldConditionOperator @relation(fields: [fieldConditionOperatorId], references: [id])

  benefitFieldConditions DimBenefitFieldCondition[] @relation("BFC_FDC")

  // Which field's answer this leaf actually evaluates. Null = self-referential — the
  // enclosing FctDynamicRuleGroup's own field (today's implicit, only behavior; every
  // existing row is null). Non-null lets a leaf reference a DIFFERENT field's answer,
  // e.g. a field's own show/hide condition depending on another field.
  conditionFieldId String?
  conditionField   DimField? @relation("FDC_DF", fields: [conditionFieldId], references: [id])

  conditionFieldValue Json @db.Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("DynamicFieldConditionCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("DynamicFieldConditionUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("fct_dynamic_field_condition")
}

// Standalone reference table — exact shape of backend/data/countries.json, not a
// DimField-scoped option list. It backs the Nationality AND Country fields' options from
// one shared dataset (see fieldOptions.service.ts's fetchFieldOptions), which a per-field
// DimFieldOption row can't do since it only ever belongs to a single fieldId.
model DimCountries {
  id String @id @default(uuid())

  numCode     String @db.VarChar(10)
  alpha2Code  String @unique @db.VarChar(2)
  alpha3Code  String @unique @db.VarChar(3)
  enShortName String @db.VarChar(255)
  nationality String @db.VarChar(255)

  // Reverse side of DimField.countries — which field(s) this row is wired to as an
  // options source (Nationality, Country, or both at once).
  fields DimField[]

  @@map("dim_countries")
}
