model DimBenefitFieldCondition {
  id String @id @default(uuid())

  benefitRuleGroupId String
  benefitRuleGroup   FctBenefitRuleGroup @relation(fields: [benefitRuleGroupId], references: [id])

  benefitFieldConditionId String
  benefitFieldCondition   FctDynamicFieldCondition   @relation("BFC_FDC", fields: [benefitFieldConditionId], references: [id])
  fieldConditions         FctDynamicFieldCondition[] @relation("FDC_BFC")

  fieldConditionOperatorId String
  fieldConditionOperator   DimFieldConditionOperator @relation(fields: [fieldConditionOperatorId], references: [id])

  conditionFieldValue Json @db.Json

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("BenefitFieldConditionCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("BenefitFieldConditionUpdatedBy", fields: [updatedById], references: [id])

  deletedAt             DateTime?
  fctDynamicRuleGroup   FctDynamicRuleGroup? @relation(fields: [fctDynamicRuleGroupId], references: [id])
  fctDynamicRuleGroupId String?

  @@map("benefit_field_condition")
}

model FctBenefitRuleGroup {
  id String @id @default(uuid())

  benefitId         String
  benefit           FctBenefit?           @relation(fields: [benefitId], references: [id])
  parentRuleGroupId String?
  parentRuleGroup   FctBenefitRuleGroup?  @relation("childFields", fields: [parentRuleGroupId], references: [id])
  childFields       FctBenefitRuleGroup[] @relation("childFields")

  logicalOperator       RuleLogicalOperator        @default(ALL)
  benefitFieldCondition DimBenefitFieldCondition[]

  @@map("fct_benefit_rule_group")
}

enum RuleLogicalOperator {
  ALL
  ANY
}

model FctDynamicRuleGroup {
  id String @id @default(uuid())

  fieldId String
  field   DimField? @relation(fields: [fieldId], references: [id])

  parentRuleGroupId String?
  parentRuleGroup   FctDynamicRuleGroup?  @relation("childFields", fields: [parentRuleGroupId], references: [id])
  childFields       FctDynamicRuleGroup[] @relation("childFields")

  benefitFieldConditions DimBenefitFieldCondition[]
  dynamicFieldConditions FctDynamicFieldCondition[]

  logicalOperator RuleLogicalOperator @default(ALL)

  @@map("fct_dynamic_rule_group")
}

model DimField {
  id String @id @default(uuid())

  // key is the normalized, snake_case form of englishName (lowercased, whitespace/
  // separators collapsed to "_") — e.g. "first_field" == "FirstField" == "FIRST FIELD"
  // == "FIRST   FIELD" == "first-FiEld" all normalize to "first_field". Postgres can't
  // enforce that kind of normalized uniqueness directly on englishName (no case/
  // whitespace-insensitive constraint), so key exists specifically to carry the
  // normalized value and be the actual @unique target — application code computes it
  // at write time.
  key String @unique @db.VarChar(255)

  parentFieldId String?
  parentField   DimField?  @relation("childFields", fields: [parentFieldId], references: [id])
  childFields   DimField[] @relation("childFields")

  englishName String @db.VarChar(255)
  tagalogName String @db.VarChar(255)
  description String

  fieldInputTypeId String
  fieldInputType   DimFieldInputType @relation(fields: [fieldInputTypeId], references: [id])

  fieldHierarchyId String?
  hierarchy        DimFieldHierarchy? @relation(fields: [fieldHierarchyId], references: [id])

  required      Boolean             @default(true)
  sortOrder     Int                 @default(0)
  configJson    Json?
  classification FieldClassification @default(FOLLOW_UP)
  default       Boolean             @default(false)

  userFieldAnswers  FctUserFieldAnswer[]
  fieldOptions      DimFieldOption[]
  dynamicRuleGroups FctDynamicRuleGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("FieldCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("FieldUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("dim_field")
}

enum FieldClassification {
  GLOBAL
  FOLLOW_UP
}

