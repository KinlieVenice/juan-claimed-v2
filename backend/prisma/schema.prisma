  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("UtilizationCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("UtilizationUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@index([deletedAt])
  @@map("fct_benefit_utilization")
