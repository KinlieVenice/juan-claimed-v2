// Im making a no code dynamic benefit finder. these comments are for claude to understand my whole project down to the schema

// Project: Juan-Claimed. No code benefits finder. Agents create the benefits and Users answers the questions/fields agents set

// THIS WHOLE STORY COMMENTS ARE FOR BENEFITS PART ONLY. FIELD AND HIERARCHY TABLES ARE FOR ANOTHER PLAN. FOR NOW I WILL ONLY EXPLAIN BENEFITS, USERS, SCOPES AND GROUPS.

// user table for authentication and authorization. this is the main user table that will be used for authentication and authorization. this is gmail sign up. it will be used to store the user information and the user role. the user role will be used to determine the access level of the user. the user role can be SUPERADMIN, AGENT, or USER. SUPERADMIN can do everything, AGENT can only create benefits and fields, and USER can only view benefits and submit applications.

// 2 are referenced in user, scopeId and groupId. scope is from the dim scope and is required when user role is AGENT and inside scope table theres: national, region, province, district, city, and barangay

// to get whats inside a specific location, we use api https://psgc.gitlab.io/api/. 

// sample api json is:
// /regions/
// [
//   {
//     "code": "130000000",
//     "name": "NCR",
//     "regionName": "National Capital Region",
//     "islandGroupCode": "luzon"
//   }
// ]

// we use scope as basis as well to know what api to call if province /province and psgcCode = code.

// Going back.

// AGENTS are the ones who will create benefits. they can only create benefits within their scope. for example, if an agent has a scope of province and a psgcCode of 34324898 which is Cavite, then they can only create benefits for that province only or selected cities/barangay etc thats within Cavite. 1 agent can only have 1 psgc code. 

// Then again, if scope for agent is national, then they can create benefits for all regions, provinces, cities, and barangays. but they have null as psgcCode. This is where group comes in

// National scope agents are often for gov departments or agencies that have benefits for all regions, provinces, cities, and barangays. so they can create benefits for all regions, provinces, cities, and barangays or just select a few. so we use group to group benefits together for natioanl. for example, if a national scope agent has a group of "Department of Health", then they can create benefits for all regions, provinces, cities, and barangays or just select a few. and all benefits created by that agent will be grouped under "Department of Health".

model DimUser {
  id                 String   @id @default(uuid())
  username           String   @unique @db.VarChar(255)
  email              String   @unique @db.VarChar(255)
  firstName          String   @db.VarChar(255)
  middleName         String?  @db.VarChar(255)
  lastName           String   @db.VarChar(255)
  passHash           String?  @db.VarChar(255)
  // True right after a Superadmin-triggered password reset — the next successful
  // password login must be followed by POST /api/auth/change-password before anything
  // else, enforced on the frontend by redirecting straight to /reset-password.
  forceResetPassword Boolean  @default(false)
  role               UserRole @default(USER)

  psgcCode String? @db.VarChar(255)

  scopeId String?
  scope   DimScope? @relation(fields: [scopeId], references: [id])

  groupId String?   @db.VarChar(255)
  group   DimGroup? @relation(fields: [groupId], references: [id])

  googleId  String? @db.VarChar(255)
  egovId    String? @db.VarChar(255)
  avatarUrl String?
  active    Boolean @default(true)

  userFieldAnswers FctUserFieldAnswer[]

  benefitsCreators               FctBenefit[]                @relation("BenefitCreatedBy")
  benefitsUpdators               FctBenefit[]                @relation("BenefitUpdatedBy")
  requirementsCreators           FctBenefitRequirement[]     @relation("RequirementCreatedBy")
  requirementsUpdators           FctBenefitRequirement[]     @relation("RequirementUpdatedBy")
  utilizationsCreators           FctBenefitUtilization[]     @relation("UtilizationCreatedBy")
  utilizationsUpdators           FctBenefitUtilization[]     @relation("UtilizationUpdatedBy")
  howToApplyCreators             FctBenefitHowToApply[]      @relation("HowToApplyCreatedBy")
  howToApplyUpdators             FctBenefitHowToApply[]      @relation("HowToApplyUpdatedBy")
  attachmentsCreators            FctAttachment[]             @relation("AttachmentCreatedBy")
  attachmentsUpdators            FctAttachment[]             @relation("AttachmentUpdatedBy")
  scopesCreators                 DimScope[]                  @relation("ScopeCreatedBy")
  scopesUpdators                 DimScope[]                  @relation("ScopeUpdatedBy")
  groupsCreators                 DimGroup[]                  @relation("GroupCreatedBy")
  groupsUpdators                 DimGroup[]                  @relation("GroupUpdatedBy")
  fieldsCreators                 DimField[]                  @relation("FieldCreatedBy")
  fieldsUpdators                 DimField[]                  @relation("FieldUpdatedBy")
  inputTypesCreators             DimFieldInputType[]         @relation("InputTypeCreatedBy")
  inputTypesUpdators             DimFieldInputType[]         @relation("InputTypeUpdatedBy")
  fieldOptionsCreators           DimFieldOption[]            @relation("FieldOptionCreatedBy")
  fieldOptionsUpdators           DimFieldOption[]            @relation("FieldOptionUpdatedBy")
  hierarchiesCreators            DimFieldHierarchy[]         @relation("HierarchyCreatedBy")
  hierarchiesUpdators            DimFieldHierarchy[]         @relation("HierarchyUpdatedBy")
  hierarchyLevelsCreators        DimFieldHierarchyLevel[]    @relation("HierarchyLevelCreatedBy")
  hierarchyLevelsUpdators        DimFieldHierarchyLevel[]    @relation("HierarchyLevelUpdatedBy")
  hierarchyNodesCreators         DimFieldHierarchyNode[]     @relation("HierarchyNodeCreatedBy")
  hierarchyNodesUpdators         DimFieldHierarchyNode[]     @relation("HierarchyNodeUpdatedBy")
  conditionOperatorsCreators     DimFieldConditionOperator[] @relation("ConditionOperatorCreatedBy")
  conditionOperatorsUpdators     DimFieldConditionOperator[] @relation("ConditionOperatorUpdatedBy")
  benefitFieldConditionsCreators DimBenefitFieldCondition[]  @relation("BenefitFieldConditionCreatedBy")
  benefitFieldConditionsUpdators DimBenefitFieldCondition[]  @relation("BenefitFieldConditionUpdatedBy")
  userFieldAnswersCreators       FctUserFieldAnswer[]        @relation("UserFieldAnswerCreatedBy")
  userFieldAnswersUpdators       FctUserFieldAnswer[]        @relation("UserFieldAnswerUpdatedBy")
  userFieldAnswerGroups          FctUserFieldAnswerGroup[]
  userFieldAnswerGroupsCreators  FctUserFieldAnswerGroup[]   @relation("UserFieldAnswerGroupCreatedBy")
  userFieldAnswerGroupsUpdators  FctUserFieldAnswerGroup[]   @relation("UserFieldAnswerGroupUpdatedBy")
  dynamicFieldConditionsCreators FctDynamicFieldCondition[]  @relation("DynamicFieldConditionCreatedBy")
  dynamicFieldConditionsUpdators FctDynamicFieldCondition[]  @relation("DynamicFieldConditionUpdatedBy")
  benefitPsgcCodesCreators       DimBenefitPsgcCode[]        @relation("BenefitPsgcCreatedBy")
  benefitPsgcCodesUpdators       DimBenefitPsgcCode[]        @relation("BenefitPsgcUpdatedBy")
  benefitGroupCreators           DimBenefitGroup[]           @relation("BenefitGroupCreatedBy")
  benefitGroupUpdators           DimBenefitGroup[]           @relation("BenefitGroupUpdatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById  String?   @db.VarChar(255)
  createdBy    DimUser?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  creatorUsers DimUser[] @relation("UserCreatedBy")

  updatedById  String?   @db.VarChar(255)
  updatedBy    DimUser?  @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  updatorUsers DimUser[] @relation("UserUpdatedBy")

  deletedAt DateTime?

  @@map("dim_user")
}

enum UserRole {
  SUPERADMIN
  AGENT
  USER
}

// for context there are the scope:
// 'NATIONAL',
// 'REGION',
// 'PROVINCE',
// 'DISTRICT'
// 'CITY',
// 'MUNICIPALITY',
// 'BARANGAY'

model DimScope {
  id    String @id @default(uuid())
  name  String @db.VarChar(255)
  value String @unique @db.VarChar(255)

  users            DimUser[]
  benefits         FctBenefit[]
  benefitPsgcCodes DimBenefitPsgcCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("ScopeCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("ScopeUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("dim_scope")
}

model DimGroup {
  id                 String @id @default(uuid())
  englishName        String @db.VarChar(255)
  tagalogName        String @db.VarChar(255)
  englishDescription String
  tagalogDescription String

  benefitGroups DimBenefitGroup[]
  users         DimUser[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("GroupCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("GroupUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@map("dim_group")
}

// now moving on to the actual benefit part. A benefit can only belong to ONE group and ONE scope but can be one to many psgcCode

// benefit can have many requirements, utilizations and even attachments. what i want to do is when i add requirement, i can attach attachment for that too same with utilization. benefit field conditions, we discuss that later after planning for benefits is done bec thats part of part 2 which is about fields.

// going back, an agent can create a benefit and if an agent is a province scope they can either make that benefit applicable to whole province or select municipality/district/barangay etc and those will be saved in dim_benefit_psgc_code and the scope will be used to query the api like /municipalities like that so its easy to know the name of that location eligible in the benefit

/**
 * The whole flow is like this. For the setting up of benefits: Agent signs up using gmail. The superadmin assigns them a scope. Then they create a benefit, select which locations under them can be eligible, add descriptions, requirements and utilizations. Agent can also add attachments (more than one possible but not required) per requirement/utilization. Then they select fields and set logic conditions on those fields and if an ordinary user answers the form and matches all those fields required then that benefit will display to him as he is eligible for this benefit.
 */

model FctBenefit {
  id String @id @default(uuid())

  scopeId String
  scope   DimScope @relation(fields: [scopeId], references: [id])

  benefitRequirements FctBenefitRequirement[]
  benefitUtilizations FctBenefitUtilization[]
  benefitHowToApplies FctBenefitHowToApply[]
  benefitPsgcCodes    DimBenefitPsgcCode[]
  benefitGroups       DimBenefitGroup[]
  benefitRuleGroups   FctBenefitRuleGroup[]

  name               String @db.VarChar(255)
  englishDescription String
  tagalogDescription String

  isNationwide Boolean @default(false)

  version Int @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("BenefitCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("BenefitUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@index([deletedAt])
  @@map("fct_benefit")
}

model DimBenefitGroup {
  id String @id @default(uuid())

  benefitId String
  benefit   FctBenefit @relation(fields: [benefitId], references: [id])

  groupId String
  group   DimGroup @relation(fields: [groupId], references: [id])

  creator Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("BenefitGroupCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("BenefitGroupUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@unique([benefitId, groupId])
  @@map("dim_benefit_group")
}

model DimBenefitPsgcCode {
  id String @id @default(uuid())

  benefitId String
  benefit   FctBenefit @relation(fields: [benefitId], references: [id])

  scopeId String
  scope   DimScope @relation(fields: [scopeId], references: [id])

  psgcCode String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("BenefitPsgcCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("BenefitPsgcUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@unique([benefitId, psgcCode])
  @@map("dim_benefit_psgc_code")
}

model FctBenefitRequirement {
  id String @id @default(uuid())

  benefitId String
  benefit   FctBenefit @relation(fields: [benefitId], references: [id])

  englishName        String @db.VarChar(255)
  tagalogName        String @db.VarChar(255)
  englishDescription String
  tagalogDescription String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("RequirementCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("RequirementUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@index([deletedAt])
  @@map("fct_benefit_requirement")
}

model FctBenefitUtilization {
  id String @id @default(uuid())

  benefitId String
