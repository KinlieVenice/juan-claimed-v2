model FctAttachment {
  id String @id @default(uuid())

  fileLabel  String @db.VarChar(255)
  fileName   String @db.VarChar(255)
  fileType   String @db.VarChar(255)
  filePath   String @db.VarChar(255)
  fileSize   BigInt
  entityId   String @db.VarChar(255) //ID IN THAT TABLE
  entityType String @db.VarChar(255) //THIS IS THE TABLE NAME
  metaData   Json   @db.Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("AttachmentCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("AttachmentUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime?

  @@index([entityType, entityId])
  @@map("fct_benefit_attachment")
