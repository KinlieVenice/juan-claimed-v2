model FctBenefitHowToApply {
  id String @id @default(uuid())

  benefitId String
  benefit   FctBenefit @relation(fields: [benefitId], references: [id])

  englishName        String @db.VarChar(255)
  tagalogName        String @db.VarChar(255)
  englishDescription String
  tagalogDescription String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?  @db.VarChar(255)
  createdBy   DimUser? @relation("HowToApplyCreatedBy", fields: [createdById], references: [id])

  updatedById String?  @db.VarChar(255)
  updatedBy   DimUser? @relation("HowToApplyUpdatedBy", fields: [updatedById], references: [id])

